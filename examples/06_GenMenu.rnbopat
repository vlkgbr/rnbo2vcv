					"numinlets" : 1,
					"numoutlets" : 0,
					"patching_rect" : [ 1254.0, 333.0, 280.0, 107.0 ],
					"text" : "The '@comment' attribute on an 'in~' object maps that inlet directly to a CV jack on the panel. Because we share the core name (e.g. 'drive_cvi' grouping with 'base_drive'), the build script perfectly aligns the CV jack in the same vertical column as the knobs!\n"
				}

			}
, 			{
				"box" : 				{
					"id" : "obj-41",
					"linecount" : 4,
					"maxclass" : "comment",
					"numinlets" : 1,
					"numoutlets" : 0,
					"patching_rect" : [ 1302.0, 215.5, 280.0, 78.0 ],
					"text" : "The 'attenv_' prefix creates a smaller bipolar knob (-1 to +1) located directly below its corresponding base knob. This acts as an attenuverter to scale the incoming CV modulation up, down, or inverted.\n"
				}

			}
, 			{
				"box" : 				{
					"id" : "obj-39",
					"linecount" : 7,
