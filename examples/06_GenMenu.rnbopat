					"patching_rect" : [ 486.0, 153.0, 167.0, 122.0 ],
					"text" : "1V/Octave Math: VCV Rack sends pitch CV at exactly 1 Volt per octave. By multiplying the CV by 12, we convert that 1V perfectly into 12 MIDI semitones before feeding it into 'mtof~'.\n"
				}

			}
, 			{
